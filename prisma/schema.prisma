generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                         String                     @id @default(cuid())
  name                       String?
  email                      String?                    @unique
  emailVerified              DateTime?
  image                      String?
  password                   String?
  role                       String                     @default("MEMBER")
  status                     String                     @default("PENDING")
  currentStage               String                     @default("STARTER_ENTRY_STAGE")
  highestStage               String                     @default("STARTER_ENTRY_STAGE")
  stageUpdatedAt             DateTime?
  finalStageCompletedAt      DateTime?
  compensationPlanStatus     String                     @default("ACTIVE")
  referralCode               String?                    @unique
  referralLink               String?
  username                   String?                    @unique
  sponsorId                  String?
  placementId                String?
  binaryPosition             String?
  onboardingStatus           String                     @default("INCOMPLETE")
  onboardingStep             Int                        @default(1)
  autoPlacement              Boolean                    @default(true)
  kycStatus                  String                     @default("PENDING")
  kycSubmittedAt             DateTime?
  kycApprovedAt              DateTime?
  kycRejectedAt              DateTime?
  kycRejectionReason         String?
  adminRole                  String?
  preferredPosition          String                     @default("LEFT")
  bankName                   String?
  accountNumber              String?
  accountName                String?
  notifyEmail                Boolean                    @default(true)
  notifySms                  Boolean                    @default(false)
  resetToken                 String?
  resetTokenExpiry           DateTime?
  leftLegCount               Int                        @default(0)
  rightLegCount              Int                        @default(0)
  totalDownlines             Int                        @default(0)
  createdAt                  DateTime                   @default(now())
  updatedAt                  DateTime                   @updatedAt
  depth                      Int                        @default(0)
  path                       String?
  sessionVersion             Int                        @default(0)
  isPasswordTemporary        Boolean                    @default(false)
  resetRequests              PasswordResetRequest[]
  activationCode             ActivationCode?            @relation("UserActivation")
  kycCode                    AdminCode?                 @relation("KycCode")
  regCode                    AdminCode?                 @relation("RegistrationCode")
  binaryTree                 BinaryTree?
  commissionsSent            CommissionLog[]            @relation("CommissionSource")
  commissionsReceived        CommissionLog[]            @relation("CommissionRecipient")
  kycSubmission              KYCSubmission?
  profile                    MemberProfile?
  refreshTokens              RefreshToken[]
  tickets                    Ticket[]
  placement                  User?                      @relation("PlacementRelation", fields: [placementId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  placed                     User[]                     @relation("PlacementRelation")
  sponsor                    User?                      @relation("SponsorRelation", fields: [sponsorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sponsored                  User[]                     @relation("SponsorRelation")
  wallet                     Wallet?
  transactions               WalletTransaction[]
  withdrawals                Withdrawal[]
  stageProgress              StageProgress[]
  stageHistory               StageHistory[]             @relation("StageHistoryMember")
  triggeredStageHistory      StageHistory[]             @relation("StageHistoryTrigger")
  qualificationSelections    QualificationContributor[] @relation("QualificationContributorQualifyingMember")
  qualificationContributions QualificationContributor[] @relation("QualificationContributorContributorMember")
  stageLoans                 StageLoan[]
  rewards                    Reward[]
  rewardClaims               RewardClaim[]

  @@index([role])
  @@index([status])
  @@index([currentStage])
  @@index([highestStage])
  @@index([compensationPlanStatus])
  @@index([kycStatus])
  @@index([sponsorId])
  @@index([placementId])
  @@index([referralCode])
  @@index([path])
  @@index([depth])
}

model Wallet {
  id           String              @id @default(cuid())
  userId       String              @unique
  balance      Decimal             @default(0)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]

  @@index([userId])
}

model WalletTransaction {
  id           String   @id @default(cuid())
  walletId     String
  userId       String
  type         String
  amount       Decimal
  balanceAfter Decimal
  description  String
  reference    String?  @unique
  metadata     String?
  status       String   @default("COMPLETED")
  createdAt    DateTime @default(now())
  eventId      String?  @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet       Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@index([reference])
  @@index([eventId])
}

model BinaryTree {
  id              String   @id @default(cuid())
  userId          String   @unique
  parentId        String?
  leftChildId     String?  @unique
  rightChildId    String?  @unique
  path            String
  depth           Int      @default(0)
  leftVolume      Decimal  @default(0)
  rightVolume     Decimal  @default(0)
  cyclesCompleted Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([path])
  @@index([depth])
  @@index([parentId])
}

model KYCSubmission {
  id          String    @id @default(cuid())
  userId      String    @unique
  fullName    String
  phone       String
  gender      String?
  dateOfBirth DateTime?
  address     String
  state       String
  lga         String?
  idType      String?
  idNumber    String?
  status      String    @default("PENDING")
  adminNote   String?
  reviewedBy  String?
  reviewedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
}

model AuditLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  targetType String?
  targetId   String?
  details    String
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([adminId])
  @@index([action])
  @@index([targetType, targetId])
  @@index([createdAt])
}

model AdminCode {
  id        String   @id @default(cuid())
  code      String   @unique
  type      String
  status    String   @default("UNUSED")
  regUserId String?  @unique
  kycUserId String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  kycUser   User?    @relation("KycCode", fields: [kycUserId], references: [id])
  regUser   User?    @relation("RegistrationCode", fields: [regUserId], references: [id])

  @@index([status])
  @@index([type])
}

model CommissionSetting {
  id          String   @id @default(cuid())
  type        String
  percentage  Decimal?
  fixedAmount Decimal?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
}

model CommissionLog {
  id         String   @id @default(cuid())
  userId     String
  fromUserId String
  level      Int
  amount     Decimal
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  eventId    String   @unique
  fromUser   User     @relation("CommissionSource", fields: [fromUserId], references: [id], onDelete: Cascade)
  user       User     @relation("CommissionRecipient", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([fromUserId])
  @@index([status])
  @@index([eventId])
}

model Content {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  body        String
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
}

model WelcomeMessage {
  id        String   @id @default(cuid())
  subject   String
  content   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Ticket {
  id        String          @id @default(cuid())
  userId    String
  subject   String
  status    String          @default("OPEN")
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  TicketMessage[]

  @@index([userId])
  @@index([status])
}

model TicketMessage {
  id        String   @id @default(cuid())
  ticketId  String
  senderId  String
  message   String
  createdAt DateTime @default(now())
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

model Withdrawal {
  id                   String       @id @default(cuid())
  userId               String
  rewardId             String?
  rewardClaimId        String?
  qualificationStage   String?
  rewardStatusSnapshot String?
  rejectionType        String?
  amount               Decimal
  method               String
  details              String
  status               String       @default("PENDING")
  adminNote            String?
  processedAt          DateTime?
  processedBy          String?
  approvedAt           DateTime?
  rejectedAt           DateTime?
  paidAt               DateTime?
  paymentReference     String?
  paymentNote          String?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  user                 User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  reward               Reward?      @relation(fields: [rewardId], references: [id], onDelete: SetNull)
  rewardClaim          RewardClaim? @relation(fields: [rewardClaimId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([rewardId])
  @@index([rewardClaimId])
  @@index([status])
  @@index([rejectionType])
  @@index([qualificationStage])
  @@index([paidAt])
}

model CommissionCycle {
  id          String   @id @default(cuid())
  startDate   DateTime
  endDate     DateTime
  status      String   @default("COMPLETED")
  totalPayout Decimal  @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
}

model AdminRole {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  permissions String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([name])
}

model ActivationCode {
  id             String    @id @default(cuid())
  code           String    @unique
  status         String    @default("UNUSED")
  createdBy      String
  createdDate    DateTime  @default(now())
  redeemedBy     String?   @unique
  redeemedDate   DateTime?
  expirationDate DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  redeemedUser   User?     @relation("UserActivation", fields: [redeemedBy], references: [id])

  @@index([status])
  @@index([code])
}

model ActivationAttempt {
  id          String   @id @default(cuid())
  userId      String
  ipAddress   String?
  attempts    Int      @default(1)
  lastAttempt DateTime @default(now())

  @@unique([userId, ipAddress])
}

model MemberProfile {
  id               String    @id @default(cuid())
  userId           String    @unique
  firstName        String?
  lastName         String?
  gender           String?
  dob              DateTime?
  phone            String?
  country          String?   @default("Nigeria")
  state            String?
  stateOfOrigin    String?
  lga              String?
  city             String?
  address          String?
  nextOfKinName    String?
  nextOfKinPhone   String?
  relationship     String?
  nextOfKinAddress String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  familyId  String
  expiresAt DateTime
  revoked   Boolean  @default(false)
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
}

model FinancialEvent {
  id        String   @id @default(cuid())
  eventId   String   @unique
  userId    String
  type      String
  amount    Decimal
  metadata  String?
  createdAt DateTime @default(now())

  @@index([eventId])
  @@index([userId])
}

model OutboxEvent {
  id                   String    @id @default(uuid())
  idempotencyKey       String    @unique
  type                 String
  userId               String
  payload              Json
  status               String    @default("OUTBOX_PENDING")
  retryCount           Int       @default(0)
  nextRetryAt          DateTime?
  lastError            String?
  failedAt             DateTime?
  processingLeaseUntil DateTime?
  processingWorkerId   String?
  executionMode        String    @default("GREEN")
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([type])
  @@index([status, nextRetryAt])
  @@index([userId])
}

model LoginAttempt {
  id          String   @id @default(cuid())
  email       String
  ipAddress   String
  attempts    Int      @default(1)
  lastAttempt DateTime @default(now())

  @@unique([email, ipAddress])
}

model PasswordResetRequest {
  id          String    @id @default(cuid())
  userId      String?
  email       String
  status      String    @default("PENDING") // PENDING, APPROVED, COMPLETED, REJECTED
  requestedAt DateTime  @default(now())
  completedAt DateTime?
  resolvedBy  String?
  reason      String?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([status])
}

model StageProgress {
  id                        String    @id @default(cuid())
  userId                    String
  stage                     String
  status                    String    @default("IN_PROGRESS") // IN_PROGRESS, COMPLETED
  leftQualifiedCount        Int       @default(0)
  rightQualifiedCount       Int       @default(0)
  qualifiedContributorCount Int       @default(0)
  requiredContributorCount  Int       @default(0)
  remainingContributorCount Int       @default(0)
  requirementStage          String?
  calculationId             String?
  qualifiedAt               DateTime?
  movedToNextStageAt        DateTime?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, stage])
  @@index([userId])
  @@index([stage])
  @@index([status])
}

model StageHistory {
  id                       String                     @id @default(cuid())
  memberId                 String
  fromStage                String
  toStage                  String
  qualifiedAt              DateTime
  qualificationRuleVersion String
  triggerMemberId          String?
  calculationId            String
  createdAt                DateTime                   @default(now())
  member                   User                       @relation("StageHistoryMember", fields: [memberId], references: [id], onDelete: Cascade)
  triggerMember            User?                      @relation("StageHistoryTrigger", fields: [triggerMemberId], references: [id], onDelete: SetNull)
  contributors             QualificationContributor[]

  @@unique([memberId, toStage])
  @@index([memberId])
  @@index([toStage])
  @@index([qualifiedAt])
  @@index([triggerMemberId])
  @@index([calculationId])
}

model QualificationContributor {
  id                              String       @id @default(cuid())
  stageHistoryId                  String
  qualifyingMemberId              String
  contributorMemberId             String
  contributorStageAtQualification String
  genealogyDepth                  Int
  contributorQualifiedAt          DateTime
  createdAt                       DateTime     @default(now())
  stageHistory                    StageHistory @relation(fields: [stageHistoryId], references: [id], onDelete: Cascade)
  qualifyingMember                User         @relation("QualificationContributorQualifyingMember", fields: [qualifyingMemberId], references: [id], onDelete: Cascade)
  contributorMember               User         @relation("QualificationContributorContributorMember", fields: [contributorMemberId], references: [id], onDelete: Cascade)

  @@unique([stageHistoryId, contributorMemberId])
  @@index([qualifyingMemberId])
  @@index([contributorMemberId])
  @@index([contributorStageAtQualification])
}

model StageLoan {
  id                 String           @id @default(cuid())
  userId             String
  stage              String
  principal          Decimal
  interestRate       Decimal
  interestAmount     Decimal
  totalRepayable     Decimal
  issuedAt           DateTime         @default(now())
  amountRepaid       Decimal          @default(0)
  outstandingBalance Decimal
  status             String           @default("ISSUED")
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  auditEntries       StageLoanAudit[]

  @@unique([userId, stage])
  @@index([userId])
  @@index([stage])
  @@index([status])
}

model StageLoanAudit {
  id        String    @id @default(cuid())
  loanId    String
  adminId   String?
  action    String
  details   String
  createdAt DateTime  @default(now())
  loan      StageLoan @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@index([loanId])
  @@index([adminId])
  @@index([action])
  @@index([createdAt])
}

model Reward {
  id            String   @id @default(cuid())
  userId        String
  stage         String
  rewardValue   Decimal
  rewardPackage String?
  status        String   @default("EARNED") // EARNED, CLAIMED, WITHDRAWAL_PENDING, WITHDRAWAL_APPROVED, WITHDRAWAL_REJECTED, PAID
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  claims      RewardClaim[]
  withdrawals Withdrawal[]

  @@unique([userId, stage])
  @@index([userId])
  @@index([stage])
  @@index([status])
}

model RewardClaim {
  id                 String    @id @default(cuid())
  rewardId           String
  userId             String
  selectedOption     String // CASH, FOOD, or PACKAGE
  status             String    @default("PENDING_ADMIN_PROCESSING") // PENDING_ADMIN_PROCESSING, PROCESSING, PAID, FULFILLED, REJECTED, CANCELLED
  adminNote          String?
  processedByAdminId String?
  processedAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  reward      Reward       @relation(fields: [rewardId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  withdrawals Withdrawal[]

  @@index([rewardId])
  @@index([userId])
  @@index([status])
}
