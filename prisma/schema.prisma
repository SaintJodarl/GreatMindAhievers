generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String    @id @default(cuid())
  name               String?
  email              String?   @unique
  emailVerified      DateTime?
  image              String?
  password           String?
  role               String    @default("MEMBER")
  status             String    @default("PENDING")
  referralCode       String?   @unique
  username           String?   @unique
  sponsorId          String?
  placementId        String?
  binaryPosition     String?
  onboardingStatus   String    @default("INCOMPLETE")
  autoPlacement      Boolean   @default(true)
  kycStatus          String    @default("PENDING")
  kycSubmittedAt     DateTime?
  kycApprovedAt      DateTime?
  kycRejectedAt      DateTime?
  kycRejectionReason String?
  adminRole          String?
  preferredPosition  String    @default("LEFT")
  bankName           String?
  accountNumber      String?
  accountName        String?
  notifyEmail        Boolean   @default(true)
  notifySms          Boolean   @default(false)
  resetToken         String?
  resetTokenExpiry   DateTime?
  leftLegCount       Int       @default(0)
  rightLegCount      Int       @default(0)
  totalDownlines     Int       @default(0)
  path               String?
  depth              Int       @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  activationCode ActivationCode? @relation("UserActivation")
  kycCode        AdminCode?      @relation("KycCode")
  regCode        AdminCode?      @relation("RegistrationCode")
  binaryTree     BinaryTree?
  kycSubmission  KYCSubmission?
  profile        MemberProfile?
  refreshTokens  RefreshToken[]
  tickets        Ticket[]

  placement User?  @relation("PlacementRelation", fields: [placementId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  placed    User[] @relation("PlacementRelation")

  sponsor   User?  @relation("SponsorRelation", fields: [sponsorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sponsored User[] @relation("SponsorRelation")

  wallet              Wallet?
  transactions        WalletTransaction[]
  withdrawals         Withdrawal[]
  commissionsReceived CommissionLog[]     @relation("CommissionRecipient")
  commissionsSent     CommissionLog[]     @relation("CommissionSource")

  @@index([role])
  @@index([status])
  @@index([kycStatus])
  @@index([sponsorId])
  @@index([placementId])
  @@index([referralCode])
  @@index([path])
  @@index([depth])
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]

  @@index([userId])
}

model WalletTransaction {
  id       String @id @default(cuid())
  walletId String
  userId   String

  type         String
  amount       Float
  balanceAfter Float
  description  String
  reference    String?  @unique
  metadata     String?
  status       String   @default("COMPLETED")
  createdAt    DateTime @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@index([reference])
}

model BinaryTree {
  id              String   @id @default(cuid())
  userId          String   @unique
  parentId        String?
  leftChildId     String?  @unique
  rightChildId    String?  @unique
  path            String
  depth           Int      @default(0)
  leftVolume      Float    @default(0)
  rightVolume     Float    @default(0)
  cyclesCompleted Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([path])
  @@index([depth])
  @@index([parentId])
}

model KYCSubmission {
  id             String  @id @default(cuid())
  userId         String  @unique
  fullName       String
  phone          String
  address        String
  state          String
  lga            String
  idType         String
  idNumber       String
  idDocument     String?
  selfie         String?
  proofOfAddress String?
  status         String  @default("PENDING")

  governmentIdUrl String?
  selfieUrl       String?
  addressProofUrl String?
  govIdStatus     String  @default("MISSING")
  selfieStatus    String  @default("MISSING")
  addressStatus   String  @default("MISSING")

  adminNote  String?
  reviewedBy String?
  reviewedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
}

model AuditLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  targetType String?
  targetId   String?
  details    String
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([adminId])
  @@index([action])
  @@index([targetType, targetId])
  @@index([createdAt])
}

model AdminCode {
  id        String   @id @default(cuid())
  code      String   @unique
  type      String
  status    String   @default("UNUSED")
  regUserId String?  @unique
  kycUserId String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  kycUser User? @relation("KycCode", fields: [kycUserId], references: [id])
  regUser User? @relation("RegistrationCode", fields: [regUserId], references: [id])

  @@index([status])
  @@index([type])
}

model CommissionSetting {
  id          String   @id @default(cuid())
  type        String
  percentage  Float?
  fixedAmount Float?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
}

model CommissionLog {
  id         String   @id @default(cuid())
  userId     String
  fromUserId String
  level      Int
  amount     Float
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User @relation("CommissionRecipient", fields: [userId], references: [id], onDelete: Cascade)
  fromUser User @relation("CommissionSource", fields: [fromUserId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([fromUserId])
  @@index([status])
}

model Content {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  body        String
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
}

model WelcomeMessage {
  id        String   @id @default(cuid())
  subject   String
  content   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Ticket {
  id        String   @id @default(cuid())
  userId    String
  subject   String
  status    String   @default("OPEN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages TicketMessage[]

  @@index([userId])
  @@index([status])
}

model TicketMessage {
  id        String   @id @default(cuid())
  ticketId  String
  senderId  String
  message   String
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

model Withdrawal {
  id          String    @id @default(cuid())
  userId      String
  amount      Float
  method      String
  details     String
  status      String    @default("PENDING")
  adminNote   String?
  processedAt DateTime?
  processedBy String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model CommissionCycle {
  id          String   @id @default(cuid())
  startDate   DateTime
  endDate     DateTime
  status      String   @default("COMPLETED")
  totalPayout Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
}

model AdminRole {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  permissions String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([name])
}

model ActivationCode {
  id             String    @id @default(cuid())
  code           String    @unique
  status         String    @default("UNUSED")
  createdBy      String
  createdDate    DateTime  @default(now())
  redeemedBy     String?   @unique
  redeemedDate   DateTime?
  expirationDate DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  redeemedUser User? @relation("UserActivation", fields: [redeemedBy], references: [id])

  @@index([status])
  @@index([code])
}

model ActivationAttempt {
  id          String   @id @default(cuid())
  userId      String
  ipAddress   String?
  attempts    Int      @default(1)
  lastAttempt DateTime @default(now())

  @@unique([userId, ipAddress])
}

model MemberProfile {
  id               String    @id @default(cuid())
  userId           String    @unique
  firstName        String?
  lastName         String?
  gender           String?
  dob              DateTime?
  phone            String?
  country          String?   @default("Nigeria")
  state            String?
  stateOfOrigin    String?
  lga              String?
  city             String?
  address          String?
  nextOfKinName    String?
  nextOfKinPhone   String?
  relationship     String?
  nextOfKinAddress String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  familyId  String
  expiresAt DateTime
  revoked   Boolean  @default(false)
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
}

model FinancialEvent {
  id        String   @id @default(cuid())
  eventId   String   @unique
  userId    String
  type      String
  amount    Float
  metadata  String? // JSON string
  createdAt DateTime @default(now())

  @@index([eventId])
  @@index([userId])
}
